# Jaeger configuration (all-in-one)
# Passed via environment variables in docker-compose.
# See: https://www.jaegertracing.io/docs/latest/deployment/

# For production use a dedicated collector + query + storage backend.
# Recommended storage backends: Elasticsearch, OpenSearch, or Cassandra.

COLLECTOR_OTLP_ENABLED=true
SPAN_STORAGE_TYPE=badger
BADGER_EPHEMERAL=false
BADGER_DIRECTORY_VALUE=/badger/data
BADGER_DIRECTORY_KEY=/badger/key
